# SABC Compliance Platform — copy to .env and fill values

PORT=3000
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
DB_PATH=./data/platform.db
SSH_KEY_PATH=./keys/ansible_id_rsa
ANSIBLE_DIR=./ansible

# JWT
JWT_SECRET=change-me-in-production-use-random-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Puppet — leave PUPPET_MASTER_HOST blank for stub mode
# PUPPET_EDITION: "enterprise" (PE Advanced; uses the commercial RBAC + Node
# Classifier APIs) or "core" (open-source Puppet; classifies via an External
# Node Classifier deployed over SSH — the no-cost production path). Can also be
# switched at runtime from the console (POST /api/infrastructure/puppet-edition).
PUPPET_EDITION=enterprise
PUPPET_MASTER_HOST=
PUPPET_MASTER_PORT=8143
PUPPET_RBAC_PORT=4433
PUPPET_ADMIN_USER=admin
PUPPET_ADMIN_PASS=
PUPPET_TOKEN_LIFETIME=1296000
PUPPET_TOKEN_ROTATE_SECONDS=43200
# Puppet Core ENC (only used when PUPPET_EDITION=core)
PUPPET_CORE_ENC_DIR=/etc/puppetlabs/puppet/enc
PUPPET_CORE_SSH_USER=root
PUPPET_CORE_DEFAULT_ENVIRONMENT=production

# Wazuh — leave blank for stub mode
WAZUH_MANAGER_HOST=
WAZUH_API_PORT=55000
WAZUH_API_USER=wazuh
WAZUH_API_PASS=
WAZUH_REG_PORT=1515
WAZUH_AGENT_PORT=1514
WAZUH_WEBHOOK_SOURCE_IP=
# Closed remediation loop: shared secret the Wazuh manager presents when posting
# alerts to /api/webhooks/wazuh. Leave blank to keep the webhook DISABLED.
WAZUH_WEBHOOK_SECRET=
# Only Wazuh alerts at/above this rule level trigger Puppet remediation.
WAZUH_WEBHOOK_MIN_LEVEL=7
# Re-scan the node automatically after remediation (true/false).
WAZUH_WEBHOOK_RESCAN=true
WAZUH_TOKEN_REFRESH_SECONDS=840

COLLECTOR_INTERVAL_SECONDS=300
SWAGGER_ENABLED=true
