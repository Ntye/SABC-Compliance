{
  "info": {
    "_postman_id": "b1f0d2a4-1c3e-4a9b-9f21-0a1b2c3d4e5f",
    "name": "Wazuh Server API (v4.x)",
    "description": "Comprehensive collection for the Wazuh server REST API (default port 55000, HTTPS, JWT auth).\n\nUSAGE\n1. Select the **Wazuh** environment (Wazuh.postman_environment.json).\n2. Set `wazuhHost`, `wazuhUser`, `wazuhPassword` for your manager.\n3. Run **Security > Login (get JWT)** once. It stores the JWT in the `token` collection/environment variable; every other request inherits Bearer auth automatically.\n4. JWT lifetime defaults to 900s — re-run Login when you get HTTP 401.\n\nNOTES\n- All requests inherit `Authorization: Bearer {{token}}` from the collection auth.\n- TLS uses a self-signed cert by default: disable SSL verification in Postman settings (Settings > General > SSL certificate verification = OFF).\n- Endpoints support common query params: `pretty`, `wait_for_complete`, `offset`, `limit`, `select`, `sort`, `search`, `q` (query), `distinct`. A few are pre-filled as examples.\n- The legacy **Vulnerability detector** folder applies to Wazuh <= 4.7; from 4.8 vulnerability data is served by the Wazuh indexer, not this API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "{{wazuhProtocol}}://{{wazuhHost}}:{{wazuhApiPort}}", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "agentId", "value": "001", "type": "string" },
    { "key": "groupId", "value": "default", "type": "string" },
    { "key": "nodeId", "value": "node01", "type": "string" }
  ],
  "item": [
    {
      "name": "Default",
      "item": [
        {
          "name": "API information (GET /)",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/?pretty=true" }
        }
      ]
    },
    {
      "name": "Security",
      "item": [
        {
          "name": "Login (get JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// With ?raw=true the body is the bare JWT string.",
                  "let token = pm.response.text();",
                  "try { const j = pm.response.json(); if (j && j.data && j.data.token) token = j.data.token; } catch (e) {}",
                  "token = (token || '').trim();",
                  "pm.collectionVariables.set('token', token);",
                  "pm.environment.set('token', token);",
                  "pm.test('Got a JWT', function () { pm.expect(token.length).to.be.above(10); });"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{wazuhUser}}", "type": "string" },
                { "key": "password", "value": "{{wazuhPassword}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/security/user/authenticate?raw=true",
            "description": "Authenticate with basic auth and obtain a JWT. `?raw=true` returns the bare token. Token TTL defaults to 900s."
          }
        },
        {
          "name": "Login as another user (run_as)",
          "request": {
            "auth": { "type": "basic", "basic": [ { "key": "username", "value": "{{wazuhUser}}", "type": "string" }, { "key": "password", "value": "{{wazuhPassword}}", "type": "string" } ] },
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/security/user/authenticate/run_as?raw=true",
            "description": "Authenticate using auth context (run_as) for authorization-context roles."
          }
        },
        { "name": "Revoke all JWTs (PUT /security/user/revoke)", "request": { "method": "PUT", "header": [], "url": "{{baseUrl}}/security/user/revoke" } },
        { "name": "Get current user (GET /security/users/me)", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/security/users/me?pretty=true" } },
        { "name": "Get current user policies (GET /security/users/me/policies)", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/security/users/me/policies?pretty=true" } },
        { "name": "List RBAC actions (GET /security/actions)", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/security/actions?pretty=true" } },
        { "name": "List RBAC resources (GET /security/resources)", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/security/resources?pretty=true" } },
        { "name": "List users (GET /security/users)", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/security/users?pretty=true" } },
        { "name": "Create user (POST /security/users)", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"username\": \"newuser\",\n  \"password\": \"SecretPassw0rd.\"\n}" }, "url": "{{baseUrl}}/security/users" } },
        { "name": "Update user (PUT /security/users/{user_id})", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"password\": \"NewSecretPassw0rd.\"\n}" }, "url": "{{baseUrl}}/security/users/2" } },
        { "name": "Delete users (DELETE /security/users)", "request": { "method": "DELETE", "header": [], "url": "{{baseUrl}}/security/users?user_ids=2" } },
        { "name": "List roles (GET /security/roles)", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/security/roles?pretty=true" } },
