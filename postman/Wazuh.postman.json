        { "name": "Delete rules (DELETE /security/rules)", "request": { "method": "DELETE", "header": [], "url": "{{baseUrl}}/security/rules?rule_ids=100" } },
        { "name": "List policies (GET /security/policies)", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/security/policies?pretty=true" } },
        { "name": "Create policy (POST /security/policies)", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"name\": \"new_policy\",\n  \"policy\": {\n    \"actions\": [\"agent:read\"],\n    \"resources\": [\"agent:id:*\"],\n    \"effect\": \"allow\"\n  }\n}" }, "url": "{{baseUrl}}/security/policies" } },
        { "name": "Update policy (PUT /security/policies/{policy_id})", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"name\": \"updated_policy\",\n  \"policy\": {\n    \"actions\": [\"agent:read\"],\n    \"resources\": [\"agent:id:*\"],\n    \"effect\": \"allow\"\n  }\n}" }, "url": "{{baseUrl}}/security/policies/100" } },
        { "name": "Delete policies (DELETE /security/policies)", "request": { "method": "DELETE", "header": [], "url": "{{baseUrl}}/security/policies?policy_ids=100" } },
        { "name": "Add roles to user (POST /security/users/{user_id}/roles)", "request": { "method": "POST", "header": [], "url": "{{baseUrl}}/security/users/2/roles?role_ids=1" } },
        { "name": "Remove roles from user (DELETE /security/users/{user_id}/roles)", "request": { "method": "DELETE", "header": [], "url": "{{baseUrl}}/security/users/2/roles?role_ids=1" } },
        { "name": "Add policies to role (POST /security/roles/{role_id}/policies)", "request": { "method": "POST", "header": [], "url": "{{baseUrl}}/security/roles/100/policies?policy_ids=1" } },
        { "name": "Remove policies from role (DELETE /security/roles/{role_id}/policies)", "request": { "method": "DELETE", "header": [], "url": "{{baseUrl}}/security/roles/100/policies?policy_ids=1" } },
        { "name": "Add rules to role (POST /security/roles/{role_id}/rules)", "request": { "method": "POST", "header": [], "url": "{{baseUrl}}/security/roles/100/rules?rule_ids=1" } },
        { "name": "Remove rules from role (DELETE /security/roles/{role_id}/rules)", "request": { "method": "DELETE", "header": [], "url": "{{baseUrl}}/security/roles/100/rules?rule_ids=1" } },
        { "name": "Get security config (GET /security/config)", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/security/config?pretty=true" } },
