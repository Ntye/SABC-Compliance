        { "name": "Update role (PUT /security/roles/{role_id})", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"name\": \"renamed_role\"\n}" }, "url": "{{baseUrl}}/security/roles/100" } },
