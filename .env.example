# ── SABC Compliance Platform — environment variables ──────────────────────────
# Copy this file to .env and fill in your values.
# The deploy script ships .env to the server automatically if it exists.

# Host port the platform is served on over HTTPS (primary entry point).
# A self-signed certificate is generated automatically on first launch.
# Defaults to 8443 so it never collides with a standard :443 service that may
# already be running on the host. Set to 443 only if that port is free.
HTTPS_PORT=8443

# Port the backend API is exposed on (for direct API / Swagger access)
BACKEND_PORT=3000

# Public address nodes use to reach this platform (IP or DNS name, no port).
# Used for two things:
#   1. Added to the self-signed TLS cert's SAN so HTTPS is valid for this
#      address (e.g. https://<this>:8443) instead of only localhost. The
#      self-signed cert is regenerated automatically if it doesn't cover it.
#   2. Baked into the node bootstrap script's cert-trust step so registered
#      nodes trust the platform cert and can call it over HTTPS without -k.
# Example (EC2 public IP): PLATFORM_PUBLIC_HOST=13.49.148.20
# Leave blank to fall back to the request Host header at bootstrap time.
PLATFORM_PUBLIC_HOST=

# ── PostgreSQL credentials ────────────────────────────────────────────────────
# These are used by both the postgres container and the backend (DATABASE_URL
# is assembled from them in docker-compose.yml). Change the password before
# going to production.
POSTGRES_DB=sabc
POSTGRES_USER=sabc
POSTGRES_PASSWORD=sabc-change-me

# ── Wazuh closed remediation loop ─────────────────────────────────────────────
# Shared secret the Wazuh manager presents (X-Wazuh-Webhook-Token) when posting
# alerts to /api/webhooks/wazuh. The same value is pushed to the manager when you
# run the "Configure remediation" action. Leave blank to keep the webhook
# DISABLED (closed by default — no alert is processed without a secret).
WAZUH_WEBHOOK_SECRET=
# Only Wazuh alerts at/above this rule level trigger Puppet remediation (7 ≈
# important, 10 ≈ high, 12 ≈ critical).
WAZUH_WEBHOOK_MIN_LEVEL=7
# Re-scan the node automatically after remediation so the dashboard reflects the
# post-enforcement compliance state (true/false).
WAZUH_WEBHOOK_RESCAN=true
# Optional CIDR/IP allowlist of permitted webhook callers (the Wazuh manager).
# Comma- or space-separated. Leave blank to rely on the shared secret alone.
WAZUH_WEBHOOK_SOURCE_IP=

# ── Optional: the host machine's LAN IP ───────────────────────────────────────
# Makes "Register this machine" work without manual typing on the Add VM page.
# Leave blank to auto-detect.
HOST_IP=

# Optional: SSH admin user on the host (default: root).
# Set to your actual user if that is how you SSH into this machine.
HOST_ADMIN_USER=

# ── Offline AI assistant (Ollama) ─────────────────────────────────────────────
# The LLM model is baked into the sabc-ollama Docker image and shipped with the
# stack, so the assistant works with NO internet on the server. The backend
# reaches it over the internal Docker network at http://ollama:11434.
#
# OLLAMA_MODEL must match the model embedded at build time (see deploy/ship.sh:
#   OLLAMA_MODEL=llama3.2:3b ./deploy/ship.sh ...). Defaults to a small model so
# the shipped archive stays light. Larger = better quality but heavier to ship:
#   llama3.2:3b (~1.3GB, default) · llama3.2:3b (~2GB) · llama3.1:8b (~4.7GB)
OLLAMA_MODEL=llama3.2:3b
