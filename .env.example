# Copy this file to .env and fill in your values before running:
#   cp .env.example .env

# ── Server ────────────────────────────────────────────────────────────────────
# Host port the platform is accessible on (maps to container port 80)
HTTP_PORT=80

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-use-a-random-32-char-string

# ── Puppet Enterprise ─────────────────────────────────────────────────────────
# Set after installing the Puppet master — can also be configured via the UI
#PUPPET_MASTER_HOST=192.168.x.x
#PUPPET_MASTER_PORT=8143

# ── Wazuh ─────────────────────────────────────────────────────────────────────
# Set after installing the Wazuh manager — can also be configured via the UI
#WAZUH_MANAGER_HOST=192.168.x.x
#WAZUH_API_PORT=55000
